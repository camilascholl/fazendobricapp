<% content_for :title, "Minha conta | Backoffice" %>

<div class="row">
  <div class="col-lg-8">
    <div class="card shadow mb-4">
      <div class="card-header py-3">
        <h1 class="h5 mb-0 text-primary">Minha conta administrativa</h1>
      </div>
      <div class="card-body">
        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
          <%= render "backoffice/shared/error_messages", resource: resource %>

          <div class="form-group">
            <%= f.label :email, "E-mail" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
          </div>

          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <div class="alert alert-warning">
              Aguardando confirmação para: <strong><%= resource.unconfirmed_email %></strong>
            </div>
          <% end %>

          <div class="form-group">
            <%= f.label :password, "Nova senha" %>
            <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
            <small class="form-text text-muted">Deixe em branco se não quiser alterar.</small>
            <% if @minimum_password_length %>
              <small class="form-text text-muted">Mínimo de <%= @minimum_password_length %> caracteres.</small>
            <% end %>
          </div>

          <div class="form-group">
            <%= f.label :password_confirmation, "Confirmar nova senha" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
          </div>

          <div class="form-group">
            <%= f.label :current_password, "Senha atual" %>
            <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
            <small class="form-text text-muted">Obrigatória para confirmar as alterações.</small>
          </div>

          <%= f.submit "Salvar alterações", class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card shadow mb-4 border-left-danger">
      <div class="card-header py-3">
        <h2 class="h5 mb-0 text-danger">Encerrar conta</h2>
      </div>
      <div class="card-body">
        <p class="text-muted">Remova definitivamente este administrador se ele não precisar mais acessar o sistema.</p>
        <%= button_to "Cancelar minha conta", registration_path(resource_name), method: :delete, data: { turbo_confirm: "Tem certeza que deseja remover esta conta?" }, class: "btn btn-danger btn-block" %>
      </div>
    </div>
  </div>
</div>
