<%= render layout: "backoffice/shared/auth_shell", locals: {
  page_title: "Desbloquear conta | Backoffice",
  heading: "Reenviar desbloqueio",
  subtitle: "Solicite um novo e-mail de desbloqueio para a conta administrativa."
} do %>
  <%= form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "user" }) do |f| %>
    <%= render "backoffice/shared/error_messages", resource: resource %>

    <div class="form-group">
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-user", placeholder: "E-mail" %>
    </div>

    <%= f.submit "Reenviar desbloqueio", class: "btn btn-primary btn-user btn-block" %>
  <% end %>

  <hr>
  <%= render "backoffice/shared/links" %>
<% end %>
