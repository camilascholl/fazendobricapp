<% content_for :title, "Editar categoria | Backoffice" %>

<section class="backoffice-hero">
  <div>
    <span class="backoffice-eyebrow">Editar</span>
    <h2 class="backoffice-hero__title"><%= @category.description %></h2>
    <p class="backoffice-hero__text">Atualize os dados da categoria selecionada.</p>
  </div>
</section>

<section class="backoffice-panel">
  <%= render "form", category: @category %>
</section>
