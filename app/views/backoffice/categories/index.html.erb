<%= javascript_importmap_tags %>

<% content_for :title, "Categorias | Backoffice" %>

<section class="backoffice-hero">
  <div>

    <h2 class="backoffice-hero__title">Categorias</h2>
    <p class="backoffice-hero__text">Gerencie as categorias usadas para organizar os anúncios.</p>
  </div>

  <div class="backoffice-actions">
    <%= link_to "Nova categoria", new_backoffice_category_path, class: "backoffice-button" %>
  </div>
</section>

<section class="backoffice-panel">
  <div class="backoffice-panel__header">
    <div>
      <span class="backoffice-eyebrow">Listagem</span>
      <h3 class="backoffice-panel__title"><%= @categories.count %> categorias existentes</h3>
    </div>
  </div>

  <% if @categories.any? %>
    <div class="backoffice-table-wrap">
      <table class="backoffice-table">
        <thead>
        <tr>
          <th>Descrição</th>
          <th>Anúncios</th>
          <th>Criada em</th>
          <th>Ações</th>
        </tr>
        </thead>
        <tbody>
        <% @categories.each do |category| %>
          <tr>
            <td><%= category.description %></td>
            <td><%= category.ads.count %></td>
            <td><%= l(category.created_at, format: :short) %></td>
            <td class="backoffice-table__actions">
              <%= link_to backoffice_category_path(category), class: "backoffice-inline-link", title: "Ver categoria" do %>
                <i class="far fa-eye" aria-hidden="true"></i>
              <% end %>
              <%= link_to edit_backoffice_category_path(category), class: "backoffice-inline-link", title: "Editar categoria" do %>
                <i class="fas fa-edit"></i>
              <% end %>
              <%= button_to backoffice_category_path(category), method: :delete, data: { turbo_confirm: "Excluir esta categoria?" }, form: { class: "backoffice-inline-form" }, class: "backoffice-inline-link backoffice-inline-link--danger backoffice-inline-button", title: "Excluir categoria" do %>
                <i class="fas fa-trash-alt" aria-hidden="true"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="backoffice-empty-state">Nenhuma categoria cadastrada ainda.</p>
  <% end %>
</section>
