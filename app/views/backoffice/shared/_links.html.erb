<div class="text-center">
  <% if controller_name != "sessions" %>
    <div class="small mb-2"><%= link_to "Entrar no painel", new_session_path(resource_name) %></div>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <div class="small mb-2"><%= link_to "Criar conta administrativa", new_registration_path(resource_name) %></div>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <div class="small mb-2"><%= link_to "Esqueci minha senha", new_password_path(resource_name) %></div>
  <% end %>

  <% if devise_mapping.confirmable? && controller_name != "confirmations" %>
    <div class="small mb-2"><%= link_to "Reenviar confirmação", new_confirmation_path(resource_name) %></div>
  <% end %>

  <% if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != "unlocks" %>
    <div class="small mb-2"><%= link_to "Reenviar desbloqueio", new_unlock_path(resource_name) %></div>
  <% end %>

  <% if devise_mapping.omniauthable? %>
    <% resource_class.omniauth_providers.each do |provider| %>
      <div class="mt-3">
        <%= button_to "Entrar com #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "btn btn-outline-secondary btn-block" %>
      </div>
    <% end %>
  <% end %>
</div>
