<aside class="backoffice-sidebar">
  <%= link_to backoffice_dashboard_path, class: "backoffice-sidebar__brand" do %>
    <div class="backoffice-sidebar__brand-icon">
        <i class="fas fa-tools" aria-hidden="true"></i>
    </div>
    <div>
      <div class="backoffice-sidebar__brand-name">Fazendo Bric</div>
      <div class="backoffice-sidebar__brand-subtitle">Painel interno</div>
    </div>
  <% end %>

  <div class="backoffice-sidebar__section">
    <span class="backoffice-sidebar__section-label">Navegação</span>

    <%= link_to backoffice_dashboard_path, class: ["backoffice-sidebar__link", ("is-active" if current_page?(backoffice_dashboard_path))].compact.join(" ") do %>
      <i class="fas fa-compass" aria-hidden="true"></i>
      <span>Visão pública</span>
    <% end %>
  </div>

  <div class="backoffice-sidebar__section backoffice-sidebar__section--note">
    <span class="backoffice-sidebar__section-label">Estado do acesso</span>
    <div class="backoffice-sidebar__note">
      Você está vendo a visualização pública do backoffice.
    </div>
    <div class="backoffice-sidebar__note">
      O modo administrativo fica separado e atualmente está sem autenticação ativa.
    </div>
  </div>
</aside>
