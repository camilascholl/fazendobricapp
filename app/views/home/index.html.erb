<% content_for :title, "Fazendo Bric | Marketplace" %>

<% hero_categories = @categories.map { |category| { description: category.description } } %>


<% showcase_ads = @featured_ads.map do |ad|
  {
    title: ad.title,
    description: ad.description,
    category_description: ad.category&.description,

  }
end %>
<% if showcase_ads.empty? %>
  <% showcase_ads = [
    { title: "Produto 1", description: "Descrição do produto 01.", category_description: "Categoria 01" },
    { title: "Produto 2", description: "Descrição do produto 02.", category_description: "Categoria 02" },
    { title: "Produto 3", description: "Descrição do produto 03.", category_description: "Categoria 03" },
    { title: "Produto 4", description: "Descrição do produto 04.", category_description: "Categoria 04" }
  ] %>
<% end %>

<div class="market-home" id="topo">
  <header class="market-topbar">
    <div class="market-shell market-topbar__inner">
      <a href="/" class="market-brand">
        <span class="market-brand__badge">F.Bric</span>
        <span class="market-brand__name">Fazendo Bric</span>
      </a>

      <form class="market-search" action="#ofertas">
        <input type="search" placeholder="Busque seu produto aqui..." aria-label="Buscar produtos">
        <button type="submit">Buscar</button>
      </form>


      <nav class="market-actions" aria-label="Acessos">
        <a href="#categorias">Categorias</a>
        <a href="#ofertas">Ofertas</a>
        <a href="/admin">Administrador</a>
      </nav>
    </div>
  </header>

  <section class="market-hero">
    <div class="market-shell">
      <div class="market-hero__grid">
        <div class="market-hero__content">
          <span class="market-kicker">Título 1</span>
          <h1>Frase1</h1>
          <p>Frase2</p>

          <div class="market-hero__cta">
            <a href="#ofertas" class="market-button market-button--primary">Botão 1</a>
            <a href="#categorias" class="market-button market-button--ghost">Botão 2</a>
          </div>

          <div class="market-highlights">
            <div>
              <strong><%= @featured_ads.size.positive? ? @featured_ads.size : 120 %>+</strong>
              <span>Anúncios em destaque</span>
            </div>
            <div>
              <strong><%= @categories.size.positive? ? @categories.size : 8 %></strong>
              <span>Categorias navegáveis</span>
            </div>
            <div>
              <strong>24h</strong>
              <span>7 dias da semana</span>
            </div>
          </div>
        </div>

        <aside class="market-promo-card">
          <span class="market-promo-card__tag">Título 1</span>
          <h2>Frase1</h2>
          <p>Frase2</p>

          <ul class="market-promo-card__list">
            <li>Item 1</li>
            <li>Item 2</li>
            <li>Item 3</li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <section class="market-strip" id="categorias">
    <div class="market-shell">
      <div class="market-strip__header">
        <div>
          <span class="market-section-label">Título 1</span>
          <h2>Categorias</h2>
        </div>
        <p>Texto 1</p>
      </div>

      <div class="market-category-row">
        <% hero_categories.each do |category| %>
          <article class="market-category-chip">
            <span class="market-category-chip__icon"><%= category[:description].to_s.first&.upcase || "01" %></span>
            <span><%= category[:description] %></span>
          </article>
        <% end %>
      </div>
    </div>
  </section>


  <section class="market-offers" id="ofertas">
    <div class="market-shell">
      <div class="market-offers__header">
        <div>
          <span class="market-section-label">Título</span>
          <h2>Destaques</h2>
        </div>
        <a href="#topo" class="market-link">Topo ^</a>
      </div>

      <div class="market-product-grid">
        <% showcase_ads.each_with_index do |ad, index| %>
          <article class="market-product-card">
            <div class="market-product-card__media market-product-card__media--<%= (index % 4) + 1 %>">
              <span><%= ad[:category_description] || "Produto" %></span>
            </div>

            <div class="market-product-card__body">
              <div class="market-product-card__meta">
                <span class="market-pill"><%= ad[:category_description] || "Categoria" %></span>
                <span class="market-rating">4.<%= 8 - (index % 3) %> ★</span>
              </div>

              <h3><%= ad[:title] %></h3>
              <p><%= truncate(ad[:description].to_s, length: 120) %></p>

              <div class="market-product-card__footer">
                <div>
                  <strong>R$ <%= number_with_precision(39.9 + (index * 18), precision: 2, separator: ",") %></strong>
                  <span>em ate 6x sem juros</span>
                </div>
                <a href="#sabermais" class="market-button market-button--primary">+</a>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    </div>
  </section>
</div>
<footer>


  <section class="market-banner">
    <div class="market-shell market-banner__inner">
      <div>
        <span class="market-section-label">Título</span>
        <h2>Frase</h2>
      </div>
    </div>
  </section>
</footer>